{% extends 'emails/layout/base.html.twig' %}

{% block subject %}Akwaaba chez Khamareo !{% endblock %}

{% block content %}
    <p>Bonjour {{ user.firstName }},</p>

    <p>Bienvenue dans l'univers du bien-être africain ! Nous sommes ravis de vous compter parmi nous.</p>

    <div class="card">
        <h3 style="margin-top: 0; text-align: center; color: #5C7357;">Pour commencer votre aventure</h3>
        <p style="text-align: center; margin-bottom: 0;">
            Veuillez confirmer votre adresse email en cliquant sur le bouton ci-dessous :
        </p>
    </div>

    <div class="btn-wrapper">
        <a href="{{ confirmationUrl }}" class="btn-primary">Confirmer mon compte</a>
    </div>

    <hr class="divider">

    <div class="card" style="text-align: center;">
        <h3 style="margin: 0 0 12px 0; color: #5C7357;">Cadeau de bienvenue</h3>
        <p style="margin: 0;">
            Une fois votre compte confirmé, vous recevrez un <strong style="color: #D8A35D;">code promo de -10%</strong> à utiliser sur votre prochaine commande !
        </p>
    </div>

    {% if newsletterSubscribed %}
    <div class="card" style="text-align: center; border-color: #D8A35D;">
        <h3 style="margin: 0 0 12px 0; color: #5C7357;">Inscription newsletter incluse</h3>
        <p style="margin: 0;">
            Vous vous êtes inscrit(e) à notre newsletter. Après confirmation de votre compte, votre abonnement sera activé et vous recevrez également un <strong style="color: #D8A35D;">code promo newsletter de -10%</strong> en bonus !
        </p>
    </div>
    {% endif %}

    <div class="highlight">
        <p style="margin: 0;">
            <strong>Le saviez-vous ?</strong><br>
            En créant votre compte, vous bénéficiez de nos offres exclusives, de la livraison suivie et d'un accès prioritaire à nos nouveautés.
        </p>
    </div>
{% endblock %}
