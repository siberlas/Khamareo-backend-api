{% extends 'emails/layout/base.html.twig' %}

{% block header %}
    <h1>🔐 Password Reset</h1>
{% endblock %}

{% block content %}
    <p>Hello {{ user.firstName }},</p>
    
    <p>You have requested to reset your password for your Khamareo account.</p>
    
    <div class="card">
        <p style="text-align: center; margin-bottom: 0;">
            Click the button below to create a new password:
        </p>
    </div>
    
    <div style="text-align: center; margin: 32px 0;">
        <a href="{{ resetUrl }}" class="button">Create New Password</a>
    </div>
    
    <p class="muted" style="font-size: 13px; text-align: center;">
        If the button doesn't work, copy and paste this link into your browser:<br>
        <a href="{{ resetUrl }}" style="color: #D8A35D; word-break: break-all;">{{ resetUrl }}</a>
    </p>
    
    <div class="alert">
        <p>
            <strong>⚠️ Security:</strong><br>
            If you didn't request this password reset, please ignore this email. Your current password will remain unchanged.
        </p>
    </div>
    
    <div class="highlight">
        <p>
            <strong>⏰ Important:</strong> This link is valid for <strong>1 hour</strong> for security reasons.
        </p>
    </div>
    
    <p class="muted" style="text-align: center; margin-top: 32px;">
        Questions about your account security? Contact us.
    </p>
{% endblock %}