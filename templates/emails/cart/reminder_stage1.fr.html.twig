{% extends 'emails/layout/base.html.twig' %}

{% block subject %}{{ isGuest ? "Vous avez oublié quelque chose chez Khamareo" : (firstName ? firstName ~ ", votre panier vous attend" : "Votre panier vous attend") }}{% endblock %}

{% block content %}
    <p>{{ greeting }},</p>

    <p>Vous avez laissé ces articles dans votre panier :</p>

    {% if cart.items is not empty %}
    <div class="card">
        <table>
            <tbody>
                {% for item in cart.items %}
                <tr style="border-bottom: 1px solid #E8DFD3;">
                    <td style="padding: 10px 8px 10px 0;">
                        <strong>{{ item.product ? item.product.name : 'Produit' }}</strong>
                        <br><span class="muted">Qté : {{ item.quantity }}</span>
                    </td>
                    <td style="padding: 10px 0; text-align: right; font-weight: 600; color: #D8A35D; white-space: nowrap;">
                        {{ (item.quantity * item.unitPrice)|format_currency('EUR', locale='fr') }}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        <div class="divider"></div>
        <table>
            <tr>
                <td style="padding: 4px 0; color: #7A5C47; text-align: right;">Sous-total</td>
                <td style="padding: 4px 0; text-align: right; font-weight: 600; white-space: nowrap; padding-left: 16px;">{{ cart.subtotal|format_currency('EUR', locale='fr') }}</td>
            </tr>
        </table>
    </div>
    {% endif %}

    <div class="btn-wrapper">
        <a href="{{ checkoutUrl }}" class="btn-primary">Finaliser ma commande</a>
    </div>

    {% if isGuest %}
    <div class="highlight">
        <p style="margin: 0;">
            💡 Vous avez commandé en tant qu'invité. Créez un compte pour suivre votre commande facilement et retrouver votre historique d'achats.
        </p>
    </div>
    {% endif %}

    <p>L'équipe Khamareo</p>
{% endblock %}
