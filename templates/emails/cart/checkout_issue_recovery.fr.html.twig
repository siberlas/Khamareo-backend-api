{% extends 'emails/layout/base.html.twig' %}

{% block subject %}Votre panier vous attend toujours{% endblock %}

{% block content %}
    <p>{{ greeting }},</p>

    <p>Vous avez laissé quelques articles dans votre panier sur Khamareo — ils sont toujours réservés pour vous.</p>

    {% if cart.items is not empty %}
    <div class="card">
        <table>
            <tbody>
                {% for item in cart.items %}
                {% set outOfStock = not item.product or item.product.stock <= 0 %}
                <tr style="border-bottom: 1px solid #E8DFD3;">
                    <td style="padding: 10px 8px 10px 0;">
                        <strong>{{ item.product ? item.product.name : 'Produit' }}</strong>
                        <br><span class="muted">Qté : {{ item.quantity }}</span>
                        {% if outOfStock %}
                        <br><span style="color: #B3261E; font-size: 12px; font-weight: 600;">Ce produit n'est plus disponible</span>
                        {% endif %}
                    </td>
                    <td style="padding: 10px 0; text-align: right; font-weight: 600; color: #D8A35D; white-space: nowrap;">
                        {{ (item.quantity * item.unitPrice)|format_currency('EUR', locale='fr') }}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        <div class="divider"></div>
        <table>
            <tr>
                <td style="padding: 4px 0; color: #7A5C47; text-align: right;">Sous-total</td>
                <td style="padding: 4px 0; text-align: right; font-weight: 600; white-space: nowrap; padding-left: 16px;">{{ cart.subtotal|format_currency('EUR', locale='fr') }}</td>
            </tr>
        </table>
    </div>
    {% endif %}

    <div class="btn-wrapper">
        <a href="{{ shopUrl }}" class="btn-primary">Retourner à la boutique</a>
    </div>

    <p class="muted">Une question sur un produit ou votre commande ? Notre équipe est joignable à <a href="mailto:akwaaba@khamareo.com">akwaaba@khamareo.com</a>.</p>

    <p>À très bientôt,<br>L'équipe Khamareo</p>
{% endblock %}
