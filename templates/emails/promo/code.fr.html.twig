{% extends 'emails/layout/base.html.twig' %}

{% block subject %}{{ message }}{% endblock %}

{% block content %}
    <p>Bonjour,</p>

    <p>Nous sommes ravis de vous offrir ce code promo exclusif pour votre prochaine commande chez Khamareo.</p>

    <div class="promo-card">
        <p style="font-size: 12px; text-transform: uppercase; letter-spacing: 2px; color: rgba(235,214,191,0.6); margin: 0 0 12px;">
            Votre code promo
        </p>
        <div class="promo-code">
            {{ promoCode.code }}
        </div>
        <p style="font-size: 22px; font-weight: 700; color: #D8A35D; margin: 12px 0 0;">
            -{{ discount }} de réduction
        </p>
    </div>

    <div class="card">
        <table width="100%" cellpadding="0" cellspacing="0">
            <tr>
                <td style="padding: 8px 0; font-size: 13px; color: #7A5C47;">Validité</td>
                <td style="padding: 8px 0; font-size: 14px; font-weight: 700; color: #4A2E20; text-align: right;">
                    Jusqu'au {{ promoCode.expiresAt|date('d/m/Y') }}
                </td>
            </tr>
            <tr>
                <td colspan="2" style="border-top: 1px solid #E8DFD3;"></td>
            </tr>
            <tr>
                <td style="padding: 8px 0; font-size: 13px; color: #7A5C47;">Cumulable</td>
                <td style="padding: 8px 0; font-size: 14px; font-weight: 700; text-align: right; color: {{ promoCode.stackable ? '#5C7357' : '#A25D3C' }};">
                    {{ promoCode.stackable ? 'Oui, avec d\'autres codes' : 'Non, ce code ne peut pas être combiné avec un autre' }}
                </td>
            </tr>
            <tr>
                <td colspan="2" style="border-top: 1px solid #E8DFD3;"></td>
            </tr>
            <tr>
                <td style="padding: 8px 0; font-size: 13px; color: #7A5C47;">Utilisation</td>
                <td style="padding: 8px 0; font-size: 14px; font-weight: 700; color: #4A2E20; text-align: right;">
                    {% if promoCode.maxUses == 1 %}
                        Usage unique
                    {% elseif promoCode.maxUses %}
                        {{ promoCode.maxUses }} utilisations max
                    {% else %}
                        Illimité
                    {% endif %}
                </td>
            </tr>
        </table>
    </div>

    <p>
        Utilisez ce code lors de votre prochaine commande pour profiter de votre réduction sur notre sélection de produits naturels africains.
    </p>

    <div class="btn-wrapper">
        <a href="{{ shopUrl }}" class="btn-primary">Découvrir nos produits</a>
    </div>

    <div class="highlight">
        <p style="margin: 0;">
            <strong>Astuce :</strong> Saisissez votre code dans le champ « Code promo » du panier ou lors du paiement.
        </p>
    </div>
{% endblock %}
