{% extends 'emails/layout/base.html.twig' %}

{% block subject %}Votre code promo Khamareo vous attend{% endblock %}

{% block content %}
    <p>Bonjour,</p>

    <p>Vous aviez obtenu un code promo chez Khamareo — il est toujours actif !</p>

    <div class="promo-card">
        <p style="font-size: 12px; text-transform: uppercase; letter-spacing: 2px; color: rgba(235,214,191,0.6); margin: 0 0 12px;">
            Votre code promo
        </p>
        <div class="promo-code">
            {{ promoCode.code }}
        </div>
        <p style="font-size: 22px; font-weight: 700; color: #D8A35D; margin: 12px 0 0;">
            -{{ discount }} de réduction
        </p>
        <p style="font-size: 13px; color: rgba(235,214,191,0.8); margin: 8px 0 0;">
            Valable jusqu'au {{ promoCode.expiresAt|date('d/m/Y') }}
        </p>
    </div>

    <p style="text-align: center; font-size: 13px; text-transform: uppercase; letter-spacing: 1px; color: #7A5C47;">
        Nos best-sellers du moment
    </p>

    <div class="card">
        <table width="100%" cellpadding="0" cellspacing="0">
            {% for product in products %}
            <tr style="{% if not loop.first %}border-top: 1px solid #E8DFD3;{% endif %}">
                <td style="padding: 10px 0;">
                    <strong style="color: #4A2E20;">{{ product.name }}</strong>
                </td>
                <td style="padding: 10px 0; text-align: right; color: #7A5C47;">
                    {{ product.price }} €
                </td>
            </tr>
            {% endfor %}
        </table>
    </div>

    <div class="btn-wrapper">
        <a href="{{ shopUrl }}" class="btn-primary">Utiliser mon code</a>
    </div>

    <div class="highlight">
        <p style="margin: 0;">
            <strong>Astuce :</strong> Saisissez votre code dans le champ « Code promo » du panier ou lors du paiement.
        </p>
    </div>
{% endblock %}
