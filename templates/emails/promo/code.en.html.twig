{% extends 'emails/layout/base.html.twig' %}

{% block subject %}{{ message }}{% endblock %}

{% block content %}
    <p>Hello,</p>

    <p>We're delighted to offer you this exclusive promo code for your next order at Khamareo.</p>

    <div class="promo-card">
        <p style="font-size: 12px; text-transform: uppercase; letter-spacing: 2px; color: rgba(235,214,191,0.6); margin: 0 0 12px;">
            Your Promo Code
        </p>
        <div class="promo-code">
            {{ promoCode.code }}
        </div>
        <p style="font-size: 22px; font-weight: 700; color: #D8A35D; margin: 12px 0 0;">
            {{ discount }} discount
        </p>
    </div>

    <div class="card">
        <table width="100%" cellpadding="0" cellspacing="0">
            <tr>
                <td style="padding: 8px 0; font-size: 13px; color: #7A5C47;">Valid until</td>
                <td style="padding: 8px 0; font-size: 14px; font-weight: 700; color: #4A2E20; text-align: right;">
                    {{ promoCode.expiresAt|date('m/d/Y') }}
                </td>
            </tr>
            <tr>
                <td colspan="2" style="border-top: 1px solid #E8DFD3;"></td>
            </tr>
            <tr>
                <td style="padding: 8px 0; font-size: 13px; color: #7A5C47;">Stackable</td>
                <td style="padding: 8px 0; font-size: 14px; font-weight: 700; text-align: right; color: {{ promoCode.stackable ? '#5C7357' : '#A25D3C' }};">
                    {{ promoCode.stackable ? 'Yes, can be combined with other codes' : 'No, this code cannot be combined with another' }}
                </td>
            </tr>
            <tr>
                <td colspan="2" style="border-top: 1px solid #E8DFD3;"></td>
            </tr>
            <tr>
                <td style="padding: 8px 0; font-size: 13px; color: #7A5C47;">Usage</td>
                <td style="padding: 8px 0; font-size: 14px; font-weight: 700; color: #4A2E20; text-align: right;">
                    {% if promoCode.maxUses == 1 %}
                        Single use
                    {% elseif promoCode.maxUses %}
                        {{ promoCode.maxUses }} uses max
                    {% else %}
                        Unlimited
                    {% endif %}
                </td>
            </tr>
        </table>
    </div>

    <p>
        Use this code on your next order to enjoy your discount on our selection of natural African products.
    </p>

    <div class="btn-wrapper">
        <a href="{{ shopUrl }}" class="btn-primary">Discover Our Products</a>
    </div>

    <div class="highlight">
        <p style="margin: 0;">
            <strong>Tip:</strong> Enter your code in the "Promo code" field in your cart or at checkout.
        </p>
    </div>
{% endblock %}
