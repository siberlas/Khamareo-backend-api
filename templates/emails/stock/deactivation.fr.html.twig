{% extends 'emails/layout/base.html.twig' %}

{% block header %}
    <h1>🔕 Alerte stock désactivée</h1>
    <p>Votre alerte a bien été supprimée</p>
{% endblock %}

{% block content %}
    <p>Bonjour {{ user.firstName ?? 'Client' }},</p>

    <p>Votre alerte stock pour <strong>{{ product.name }}</strong> a été désactivée.</p>

    <p>Vous pouvez la réactiver à tout moment depuis la page du produit :</p>

    <div style="text-align: center; margin: 24px 0;">
        <a href="{{ productUrl }}" class="button">Voir le produit</a>
    </div>

    <p class="muted">
        Gestion des alertes : <a href="{{ manageAlertsUrl }}">Gérer mes alertes</a>
    </p>
{% endblock %}
