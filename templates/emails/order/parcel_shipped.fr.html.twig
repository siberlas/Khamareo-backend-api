{% extends 'emails/layout/base.html.twig' %}

{% block subject %}Colis {{ parcelNumber }}/{{ totalParcels }} expédié !{% endblock %}

{% block content %}
    <p>{{ greeting }},</p>

    <p>Le <strong>colis {{ parcelNumber }}/{{ totalParcels }}</strong> de votre commande
    <strong style="color: #D8A35D;">#{{ order.orderNumber }}</strong> vient d'être expédié.</p>

    {% if totalParcels > 1 %}
    <div class="card" style="text-align: center;">
        <p style="margin: 0; font-size: 14px; color: #7A5C47;">
            Avancement de votre commande
        </p>
        <p style="margin: 8px 0 0; font-size: 20px; font-weight: 700; color: #D8A35D;">
            {{ parcelNumber }} / {{ totalParcels }} colis expédié{{ parcelNumber > 1 ? 's' : '' }}
        </p>
    </div>
    {% endif %}

    {% if trackingNumber %}
    <div class="highlight">
        <p style="margin: 0 0 8px;">
            <strong>Numéro de suivi :</strong>
            <span style="font-size: 17px; font-family: monospace; color: #4A2E20; letter-spacing: 1px;">{{ trackingNumber }}</span>
        </p>
    </div>
    {% endif %}

    <div class="btn-wrapper">
        <a href="{{ trackingUrl }}" class="btn-primary">Suivre ma commande</a>
    </div>

    {# Contenu du colis #}
    {% if parcel.items is not empty %}
    <div class="card">
        <h3 style="margin-top: 0; color: #4A2E20;">Contenu du colis {{ parcelNumber }}</h3>
        <table class="order-table">
            <tbody>
                {% for parcelItem in parcel.items %}
                <tr>
                    <td style="padding: 10px 8px 10px 0;">
                        <strong>{{ parcelItem.orderItem.product ? parcelItem.orderItem.product.name : (parcelItem.orderItem.productName ?? 'Produit') }}</strong>
                        <br><span class="muted">Qté : {{ parcelItem.quantity }}</span>
                    </td>
                    <td style="padding: 10px 0; text-align: right; font-weight: 600; color: #D8A35D; white-space: nowrap;">
                        {{ (parcelItem.quantity * parcelItem.orderItem.unitPrice)|format_currency('EUR', locale='fr') }}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {# Articles restants à expédier #}
    {% if remainingItems is not empty %}
    <div class="highlight">
        <p style="margin: 0 0 8px;"><strong>Articles restants à expédier :</strong></p>
        <ul style="margin: 0; padding-left: 20px;">
            {% for item in remainingItems %}
            <li style="margin-bottom: 4px;">{{ item.name }} (x{{ item.quantity }})</li>
            {% endfor %}
        </ul>
        <p style="margin: 8px 0 0; font-size: 13px; color: #7A5C47;">
            Ces articles vous seront envoyés très prochainement dans un prochain colis. Vous recevrez un email avec le numéro de suivi dès l'expédition.
        </p>
    </div>
    {% endif %}
    {% endif %}

    {# Adresse de livraison #}
    {% if order.shippingAddress %}
    <div class="card">
        {% if order.isRelayPoint %}
        <h3 style="margin-top: 0; color: #4A2E20;">Votre Point Relais</h3>
        <p style="margin: 0 0 8px; font-size: 13px;">
            <span class="tag">{{ order.carrier ? order.carrier.name : (order.relayCarrier ?? 'Point Relais') }}</span>
        </p>
        {% if order.relayPointId %}
        <p style="margin: 0 0 6px;" class="muted">
            Identifiant du point relais : <strong style="font-family: monospace;">{{ order.relayPointId }}</strong>
        </p>
        {% endif %}
        <p style="margin: 0; line-height: 1.8;">
            <strong>{{ order.shippingAddress.firstName }} {{ order.shippingAddress.lastName }}</strong><br>
            {{ order.shippingAddress.streetAddress ?? order.shippingAddress.street }}<br>
            {{ order.shippingAddress.postalCode }} {{ order.shippingAddress.city }}<br>
            {{ order.shippingAddress.country }}
        </p>
        <p style="margin-top: 10px; margin-bottom: 0; font-size: 12px; color: #7A5C47;">
            Pensez à vous munir d'une pièce d'identité pour retirer votre colis.
        </p>
        {% else %}
        <h3 style="margin-top: 0; color: #4A2E20;">Adresse de livraison</h3>
        <p style="margin: 0; line-height: 1.8;">
            <strong>{{ order.shippingAddress.firstName }} {{ order.shippingAddress.lastName }}</strong><br>
            {{ order.shippingAddress.streetAddress ?? order.shippingAddress.street }}<br>
            {{ order.shippingAddress.postalCode }} {{ order.shippingAddress.city }}<br>
            {{ order.shippingAddress.country }}
        </p>
        {% endif %}
    </div>
    {% endif %}

    <p class="muted" style="text-align: center;">
        Des questions ? Contactez-nous à <a href="mailto:akwaaba@khamareo.com" style="color: #D8A35D;">akwaaba@khamareo.com</a>
    </p>
{% endblock %}
