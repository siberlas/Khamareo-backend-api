{% extends 'emails/layout/base.html.twig' %}

{% block header %}
    <h1>✅ Commande confirmée !</h1>
    <p>Merci pour votre confiance</p>
{% endblock %}

{% block content %}
    <p>{{ greeting }},</p>
    
    <p>Nous avons bien reçu votre commande <strong style="color: #D8A35D;">#{{ order.orderNumber }}</strong> et votre paiement a été confirmé avec succès.</p>
    
    <div class="highlight">
        <p><strong>🎉 Votre commande est en cours de préparation</strong></p>
    </div>
    
    <div class="card">
        <h2 style="margin-top: 0;">📦 Détails de votre commande</h2>
        
        <table style="margin: 24px 0;">
            <thead>
                <tr style="border-bottom: 2px solid #E8DFD3;">
                    <th style="padding: 12px 8px 12px 0; text-align: left; font-family: 'Open Sans', Arial, sans-serif; font-weight: 600; color: #4A2E20;">
                        Produit
                    </th>
                    <th style="padding: 12px 8px; text-align: right; font-family: 'Open Sans', Arial, sans-serif; font-weight: 600; color: #4A2E20;">
                        Prix
                    </th>
                    <th style="padding: 12px 0 12px 8px; text-align: right; font-family: 'Open Sans', Arial, sans-serif; font-weight: 600; color: #4A2E20;">
                        Total
                    </th>
                </tr>
            </thead>
            <tbody>
                {% for item in order.items %}
                <tr style="border-bottom: 1px solid #E8DFD3;">
                    <td style="padding: 16px 8px 16px 0;">
                        <strong>{{ item.product.name }}</strong><br>
                        <span class="muted">Quantité : {{ item.quantity }}</span>
                    </td>
                    <td style="padding: 16px 8px; text-align: right; white-space: nowrap;">
                        {{ item.unitPrice|format_currency('EUR', locale='fr') }}
                    </td>
                    <td style="padding: 16px 0 16px 8px; text-align: right; font-weight: 700; color: #D8A35D; white-space: nowrap;">
                        {{ (item.quantity * item.unitPrice)|format_currency('EUR', locale='fr') }}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        
        <div class="divider"></div>
        
        <table style="margin-top: 16px;">
            <tr>
                <td colspan="2" style="padding: 8px 0; text-align: right; color: #7A5C47;">
                    Sous-total
                </td>
                <td style="padding: 8px 0; text-align: right; font-weight: 600; white-space: nowrap;">
                    {{ itemsTotal|format_currency(order.currency, locale=locale) }}
                </td>
            </tr>

            {% if order.promoCodesData is not empty %}
                {% for promoItem in order.promoCodesData %}
                <tr>
                    <td colspan="2" style="padding: 8px 0; text-align: right; color: #A25D3C;">
                        <span style="background-color: #F2C879; padding: 4px 8px; border-radius: 6px; font-size: 13px; font-weight: 600;">
                            {{ promoItem.code }}
                        </span>
                        Code promo
                    </td>
                    <td style="padding: 8px 0; text-align: right; color: #A25D3C; font-weight: 700; white-space: nowrap;">
                        - {{ promoItem.discount|format_currency(order.currency, locale=locale) }}
                    </td>
                </tr>
                {% endfor %}
            {% elseif order.promoCode %}
            <tr>
                <td colspan="2" style="padding: 8px 0; text-align: right; color: #A25D3C;">
                    <span style="background-color: #F2C879; padding: 4px 8px; border-radius: 6px; font-size: 13px; font-weight: 600;">
                        {{ order.promoCode }}
                    </span>
                    Code promo
                </td>
                <td style="padding: 8px 0; text-align: right; color: #A25D3C; font-weight: 700; white-space: nowrap;">
                    - {{ order.discountAmount|format_currency(order.currency, locale=locale) }}
                </td>
            </tr>
            {% endif %}

            <tr>
                <td colspan="2" style="padding: 8px 0; text-align: right; color: #7A5C47;">
                    Livraison{% if order.shippingMode %} — {{ order.shippingMode.name }}{% elseif order.carrier %} — {{ order.carrier.name }}{% endif %}
                </td>
                <td style="padding: 8px 0; text-align: right; font-weight: 600; white-space: nowrap;">
                    {% if order.shippingCost is not null and order.shippingCost > 0 %}
                        {{ order.shippingCost|format_currency(order.currency, locale=locale) }}
                    {% else %}
                        <span style="color: #5C7357;">Gratuit</span>
                    {% endif %}
                </td>
            </tr>

            <tr style="background-color: #F9F5F0;">
                <td colspan="2" style="padding: 16px 12px; text-align: right;">
                    <strong style="font-size: 18px; font-family: 'Libre Baskerville', Georgia, serif;">TOTAL</strong>
                </td>
                <td style="padding: 16px 12px; text-align: right; font-size: 22px; font-weight: 700; color: #D8A35D; white-space: nowrap;">
                    {{ order.totalAmount|format_currency(order.currency, locale=locale) }}
                </td>
            </tr>
        </table>
    </div>

    {% if order.shippingAddress %}
    <div class="card">
        <h3 style="margin-top: 0;">🚚 Informations de livraison</h3>

        <div style="background-color: #FFFFFF; padding: 16px; border-left: 3px solid #D8A35D; border-radius: 6px; margin: 16px 0;">
            <strong>{{ order.shippingAddress.firstName }} {{ order.shippingAddress.lastName }}</strong><br>
            {{ order.shippingAddress.streetAddress }}<br>
            {{ order.shippingAddress.postalCode }} {{ order.shippingAddress.city }}<br>
            {{ order.shippingAddress.country }}
            {% if order.shippingAddress.phone %}
            <br><span class="muted">☎️ {{ order.shippingAddress.phone }}</span>
            {% endif %}
        </div>

        {% if order.shippingMethod %}
        <p class="muted" style="margin-top: 16px;">
            <strong>Mode de livraison :</strong> {{ order.shippingMethod.name }}
        </p>
        {% endif %}
    </div>
    {% endif %}
    
    <div style="text-align: center; margin: 32px 0;">
        <a href="{{ trackingUrl }}" class="button">Suivre ma commande</a>
    </div>
    
    <div class="highlight">
        <p>
            <strong>📬 Prochaine étape :</strong><br>
            Vous recevrez un email dès que votre colis sera expédié avec votre numéro de suivi.
        </p>
    </div>
    
    <p class="muted" style="text-align: center; margin-top: 32px;">
        Des questions ? Notre équipe est là pour vous aider !
    </p>
{% endblock %}