{% extends 'emails/layout/base.html.twig' %}

{% block subject %}Your order has been cancelled{% endblock %}

{% block content %}
    <p>{{ greeting }},</p>

    <p>We're writing to let you know that your order <strong>#{{ order.orderNumber }}</strong> has been cancelled.</p>

    {% if reason %}
    <div class="highlight">
        <p style="margin: 0 0 4px; font-size: 13px; color: #7A5C47; font-weight: 600;">Reason for cancellation</p>
        <p style="margin: 0; color: #4A2E20;">{{ reason }}</p>
    </div>
    {% endif %}

    {% if adminMessage %}
    <div class="card">
        <p style="margin: 0 0 6px; font-size: 13px; color: #7A5C47; font-weight: 600;">Message from our team</p>
        <p style="margin: 0; color: #4A2E20; white-space: pre-wrap;">{{ adminMessage }}</p>
    </div>
    {% endif %}

    {# ── Order summary ─────────────────────── #}
    {% if order.items is not empty %}
    <div class="card">
        <h3 style="margin-top: 0; color: #4A2E20;">Order Summary — #{{ order.orderNumber }}</h3>
        <table>
            <tbody>
                {% for item in order.items %}
                <tr style="border-bottom: 1px solid #E8DFD3;">
                    <td style="padding: 10px 8px 10px 0;">
                        <strong>{{ item.product ? item.product.name : (item.productName ?? 'Product') }}</strong>
                        <br><span class="muted">Qty: {{ item.quantity }}</span>
                    </td>
                    <td style="padding: 10px 0; text-align: right; font-weight: 600; color: #D8A35D; white-space: nowrap;">
                        {{ (item.quantity * item.unitPrice)|format_currency('EUR', locale='en') }}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        <div class="divider"></div>
        <table>
            {% if order.shippingCost > 0 %}
            <tr>
                <td style="padding: 4px 0; color: #7A5C47; text-align: right;">Shipping</td>
                <td style="padding: 4px 0; text-align: right; font-weight: 600; white-space: nowrap; padding-left: 16px;">{{ order.shippingCost|format_currency('EUR', locale='en') }}</td>
            </tr>
            {% endif %}
            <tr>
                <td style="padding: 4px 0; color: #7A5C47; text-align: right;">Total</td>
                <td style="padding: 4px 0; text-align: right; font-weight: 600; white-space: nowrap; padding-left: 16px;">{{ order.totalAmount|format_currency('EUR', locale='en') }}</td>
            </tr>
        </table>
    </div>
    {% endif %}

    {% if order.paymentStatus == 'paid' %}
    <p>If you have already been charged, a refund will be processed within the next few days.</p>
    {% endif %}

    <p class="muted" style="text-align: center;">
        Questions? Contact us at <a href="mailto:akwaaba@khamareo.com" style="color: #D8A35D;">akwaaba@khamareo.com</a>
    </p>
{% endblock %}
