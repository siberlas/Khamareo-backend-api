{% extends 'emails/layout/base.html.twig' %}

{% block subject %}Order Being Prepared{% endblock %}

{% block content %}
    <p>{{ greeting }},</p>

    <p>Great news! Your order <strong style="color: #D8A35D;">#{{ order.orderNumber }}</strong>
    is now <strong>being prepared</strong>. We are carefully packing your parcel.</p>

    {# ── Delays ───────────────────────────────────────────────── #}
    <div class="highlight">
        {% if dispatchDelay %}
        <p style="margin: 0 0 6px;">
            <strong>Dispatch delay:</strong> {{ dispatchDelay }}
        </p>
        {% endif %}
        {% if deliveryDelay %}
        <p style="margin: 0 0 {% if deliveryNote %}6px{% else %}0{% endif %};">
            <strong>Estimated delivery time:</strong> {{ deliveryDelay }}
            {% if order.carrier %} with <strong>{{ order.carrier.name }}</strong>{% endif %}
        </p>
        {% else %}
        <p style="margin: 0;">
            You will receive an email as soon as your parcel is shipped, with your tracking number.
        </p>
        {% endif %}
        {% if deliveryNote %}
        <p style="margin: 0; font-size: 12px; opacity: 0.75;">{{ deliveryNote }}</p>
        {% endif %}
    </div>

    {# ── Items ────────────────────────────────────────────────── #}
    {% if order.items is not empty %}
    <div class="card">
        <h3 style="margin-top: 0; color: #4A2E20;">Order Summary</h3>
        <table>
            <tbody>
                {% for item in order.items %}
                <tr style="border-bottom: 1px solid #E8DFD3;">
                    <td style="padding: 10px 8px 10px 0;">
                        <strong>{{ item.product ? item.product.name : (item.productName ?? 'Product') }}</strong>
                        <br><span class="muted">Qty: {{ item.quantity }}</span>
                    </td>
                    <td style="padding: 10px 0; text-align: right; font-weight: 600; color: #D8A35D; white-space: nowrap;">
                        {{ (item.quantity * item.unitPrice)|format_currency('EUR') }}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        <div class="divider"></div>
        <table>
            {% if order.shippingCost > 0 %}
            <tr>
                <td style="padding: 4px 0; color: #7A5C47; text-align: right;">Shipping</td>
                <td style="padding: 4px 0; text-align: right; font-weight: 600; white-space: nowrap; padding-left: 16px;">{{ order.shippingCost|format_currency('EUR') }}</td>
            </tr>
            {% endif %}
            <tr>
                <td style="padding: 8px 0; text-align: right;"><strong>Total</strong></td>
                <td style="padding: 8px 0; text-align: right; font-weight: 700; color: #D8A35D; font-size: 16px; white-space: nowrap; padding-left: 16px;">{{ order.totalAmount|format_currency('EUR') }}</td>
            </tr>
        </table>
    </div>
    {% endif %}

    {# ── Address / Pickup point ───────────────────────────────── #}
    {% if order.shippingAddress %}
    <div class="card">
        {% if order.isRelayPoint %}
        <h3 style="margin-top: 0; color: #4A2E20;">Pickup Point</h3>
        <p style="margin: 0 0 6px; font-size: 13px;">
            <span class="tag">{{ order.carrier ? order.carrier.name : (order.relayCarrier ?? 'Pickup Point') }}</span>
        </p>
        {% if order.relayPointId %}
        <p style="margin: 0 0 6px;" class="muted">Pickup point ID: <strong>{{ order.relayPointId }}</strong></p>
        {% endif %}
        <p style="margin: 0; line-height: 1.8;">
            <strong>{{ order.shippingAddress.firstName }} {{ order.shippingAddress.lastName }}</strong><br>
            {{ order.shippingAddress.streetAddress ?? order.shippingAddress.street }}<br>
            {{ order.shippingAddress.postalCode }} {{ order.shippingAddress.city }}<br>
            {{ order.shippingAddress.country }}
        </p>
        {% else %}
        <h3 style="margin-top: 0; color: #4A2E20;">Delivery Address</h3>
        <p style="margin: 0; line-height: 1.8;">
            <strong>{{ order.shippingAddress.firstName }} {{ order.shippingAddress.lastName }}</strong><br>
            {{ order.shippingAddress.streetAddress ?? order.shippingAddress.street }}<br>
            {{ order.shippingAddress.postalCode }} {{ order.shippingAddress.city }}<br>
            {{ order.shippingAddress.country }}
        </p>
        {% endif %}
        {% if order.carrier %}
        <p class="muted" style="margin-top: 12px; margin-bottom: 0;">
            Carrier: <strong>{{ order.carrier.name }}</strong>
            {% if order.shippingMode %} — {{ order.shippingMode.name }}{% endif %}
        </p>
        {% endif %}
    </div>
    {% endif %}

    <div style="text-align: center; margin: 28px 0;">
        <a href="{{ orderUrl }}" class="btn-primary">View my order</a>
    </div>

    <p class="muted" style="text-align: center;">
        Questions? Contact us at <a href="mailto:akwaaba@khamareo.com" style="color: #D8A35D;">akwaaba@khamareo.com</a>
    </p>
{% endblock %}
