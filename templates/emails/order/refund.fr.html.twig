{% extends 'emails/layout/base.html.twig' %}

{% block subject %}Remboursement effectué{% endblock %}

{% block content %}
    <p>{{ greeting }},</p>

    <p>Votre remboursement a bien été effectué suite à votre demande.<br>
    Les fonds devraient apparaître sur votre compte bancaire <strong>dans quelques jours</strong>, selon les délais de votre établissement bancaire.</p>

    {# ── Montant remboursé ─────────────────────────────────── #}
    <div class="highlight" style="text-align: center;">
        <p style="margin: 0 0 6px; font-size: 13px; color: #7A5C47;">Montant remboursé</p>
        <p style="margin: 0; font-size: 32px; font-weight: 700; color: #4A2E20;">
            {{ refundAmount|format_currency('EUR', locale='fr') }}
        </p>
        {% if refundId %}
        <p style="margin: 10px 0 0; font-size: 12px; color: #7A5C47;">
            Référence remboursement : <span style="font-family: monospace; color: #4A2E20;">{{ refundId }}</span>
        </p>
        {% endif %}
    </div>

    {# ── Récapitulatif de la commande ─────────────────────── #}
    {% if order.items is not empty %}
    <div class="card">
        <h3 style="margin-top: 0; color: #4A2E20;">Récapitulatif — Commande #{{ order.orderNumber }}</h3>
        <table>
            <tbody>
                {% for item in order.items %}
                <tr style="border-bottom: 1px solid #E8DFD3;">
                    <td style="padding: 10px 8px 10px 0;">
                        <strong>{{ item.product ? item.product.name : (item.productName ?? 'Produit') }}</strong>
                        <br><span class="muted">Qté : {{ item.quantity }}</span>
                    </td>
                    <td style="padding: 10px 0; text-align: right; font-weight: 600; color: #D8A35D; white-space: nowrap;">
                        {{ (item.quantity * item.unitPrice)|format_currency('EUR', locale='fr') }}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        <div class="divider"></div>
        <table>
            {% if order.shippingCost > 0 %}
            <tr>
                <td style="padding: 4px 0; color: #7A5C47; text-align: right;">Livraison</td>
                <td style="padding: 4px 0; text-align: right; font-weight: 600; white-space: nowrap; padding-left: 16px;">{{ order.shippingCost|format_currency('EUR', locale='fr') }}</td>
            </tr>
            {% endif %}
            <tr>
                <td style="padding: 4px 0; color: #7A5C47; text-align: right;">Total payé</td>
                <td style="padding: 4px 0; text-align: right; font-weight: 600; white-space: nowrap; padding-left: 16px;">{{ order.totalAmount|format_currency('EUR', locale='fr') }}</td>
            </tr>
            <tr>
                <td style="padding: 8px 0; text-align: right;"><strong style="color: #4A2E20;">Remboursé</strong></td>
                <td style="padding: 8px 0; text-align: right; font-weight: 700; color: #D8A35D; font-size: 16px; white-space: nowrap; padding-left: 16px;">{{ refundAmount|format_currency('EUR', locale='fr') }}</td>
            </tr>
        </table>
    </div>
    {% endif %}

    <div style="text-align: center; margin: 24px 0;">
        <a href="{{ orderUrl }}" class="btn-primary">Voir ma commande</a>
    </div>

    <p class="muted" style="text-align: center;">
        Des questions ? Contactez-nous à <a href="mailto:akwaaba@khamareo.com" style="color: #D8A35D;">akwaaba@khamareo.com</a>
    </p>
{% endblock %}
