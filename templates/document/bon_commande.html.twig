<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        @page { margin: 0; }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 11px; color: #111; line-height: 1.4; padding: 30px 60px; }

        .header { display: flex; justify-content: space-between; align-items: flex-start; padding-bottom: 10px; margin-bottom: 12px; }
        .header-left { display: flex; align-items: center; gap: 10px; }
        .logo-img { height: 32px; width: auto; }
        .brand-name { font-size: 18px; font-weight: 600; color: #111; letter-spacing: 0.06em; text-transform: uppercase; }
        .brand-tagline { font-size: 9px; font-style: italic; color: #666; margin-top: 2px; }
        .doc-meta { text-align: right; }
        .doc-title { font-size: 15px; font-weight: 700; color: #111; text-transform: uppercase; letter-spacing: 0.1em; }
        .doc-ref { font-size: 10px; color: #444; margin-top: 3px; }

        .gold-bar { height: 2px; background: #333; margin-bottom: 14px; }

        .addresses { display: flex; gap: 16px; margin-bottom: 14px; }
        .address-block { flex: 1; padding: 10px 14px; border: 1px solid #999; border-radius: 4px; }
        .address-block h3 { font-size: 9px; text-transform: uppercase; letter-spacing: 0.1em; color: #333; margin-bottom: 5px; padding-bottom: 3px; border-bottom: 1px solid #ccc; }
        .address-block p { margin: 1px 0; font-size: 10px; }

        .order-info { padding: 8px 14px; margin-bottom: 12px; font-size: 10px; border-left: 3px solid #333; background: #f5f5f5; }
        .order-info span { margin-right: 24px; }

        table { width: 100%; border-collapse: collapse; margin-bottom: 12px; }
        thead th { background: #222; color: white; padding: 8px 10px; text-align: left; font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
        thead th.text-right { text-align: right; }
        tbody tr:nth-child(even) { background: #f5f5f5; }
        tbody td { padding: 7px 10px; border-bottom: 1px solid #ddd; font-size: 11px; }
        tbody td.text-right { text-align: right; }

        .totals-section { display: flex; justify-content: flex-end; margin-top: 6px; }
        .totals-table { width: 260px; border-collapse: collapse; }
        .totals-table td { padding: 6px 10px; border-bottom: 1px solid #ddd; font-size: 11px; }
        .totals-table td:last-child { text-align: right; font-weight: 600; }
        .totals-table .row-discount td { color: #333; }
        .totals-table .row-total { background: #222; color: white; }
        .totals-table .row-total td { font-size: 12px; font-weight: 700; border: none; padding: 8px 10px; }

        .payment-info { margin-top: 12px; font-size: 9px; color: #555; border-top: 1px solid #ccc; padding-top: 6px; }
        .footer { margin-top: 16px; padding-top: 8px; border-top: 1px solid #ccc; font-size: 9px; color: #666; text-align: center; }
    </style>
</head>
<body>

{% set customerName = order.owner
    ? (order.owner.firstName ~ ' ' ~ order.owner.lastName)
    : (order.guestFirstName ~ ' ' ~ order.guestLastName) %}
{% set customerEmail = order.owner ? order.owner.email : order.guestEmail %}

<div class="header">
    <div>
        <div class="header-left">
            <img src="https://res.cloudinary.com/dtdumh0gv/image/upload/v1774628630/logo-khamareo_t0wufe.png" alt="Khamareo" class="logo-img">
            <div>
                <div class="brand-name">Khamareo</div>
                <div class="brand-tagline">Une vie saine au naturel</div>
            </div>
        </div>
        <div style="font-size: 9px; color: #999; margin-top: 6px;">
            akwaaba@khamareo.com — www.khamareo.com<br>
            {% if sellerLegalForm is defined and sellerLegalForm %}{{ sellerLegalForm }}{% endif %}{% if sellerSiren is defined and sellerSiren %} — SIREN : {{ sellerSiren }}{% endif %}<br>
            {% if sellerAddress is defined and sellerAddress %}{{ sellerAddress }}{% endif %}
        </div>
    </div>
    <div class="doc-meta">
        <div class="doc-title">Bon de Commande</div>
        <div class="doc-ref">
            N° {{ order.orderNumber }}<br>
            Émis le {{ generatedAt|date('d/m/Y') }}
        </div>
    </div>
</div>

<div class="gold-bar"></div>

<div class="addresses">
    <div class="address-block">
        <h3>Expéditeur</h3>
        <p><strong>Khamareo</strong></p>
        <p>akwaaba@khamareo.com</p>
        <p>www.khamareo.com</p>
    </div>
    <div class="address-block">
        <h3>Client</h3>
        <p><strong>{{ customerName }}</strong></p>
        {% if order.shippingAddress %}
            <p>{{ order.shippingAddress.streetAddress }}</p>
            <p>{{ order.shippingAddress.postalCode }} {{ order.shippingAddress.city }}</p>
            <p>{{ order.shippingAddress.country }}</p>
        {% endif %}
        <p>{{ customerEmail }}</p>
    </div>
    {% if order.billingAddress %}
    <div class="address-block">
        <h3>Facturation</h3>
        <p><strong>{{ customerName }}</strong></p>
        <p>{{ order.billingAddress.streetAddress }}</p>
        <p>{{ order.billingAddress.postalCode }} {{ order.billingAddress.city }}</p>
        <p>{{ order.billingAddress.country }}</p>
    </div>
    {% endif %}
</div>

<div class="order-info">
    <span><strong>Commande :</strong> {{ order.orderNumber }}</span>
    <span><strong>Date :</strong> {{ order.createdAt|date('d/m/Y') }}</span>
    <span><strong>Statut :</strong> {{ order.statusLabel }}</span>
</div>

<table>
    <thead>
        <tr>
            <th>Désignation</th>
            <th class="text-right">Prix unitaire</th>
            <th class="text-right" style="width:50px">Qté</th>
            <th class="text-right">Total</th>
        </tr>
    </thead>
    <tbody>
        {% for item in order.items %}
        <tr>
            <td><strong>{{ item.product.name }}</strong></td>
            <td class="text-right">{{ item.unitPrice|number_format(2, ',', ' ') }} €</td>
            <td class="text-right">{{ item.quantity }}</td>
            <td class="text-right">{{ (item.unitPrice * item.quantity)|number_format(2, ',', ' ') }} €</td>
        </tr>
        {% endfor %}
    </tbody>
</table>

{% set subtotal = order.totalAmount - order.shippingCost %}
<div class="totals-section">
    <table class="totals-table">
        <tr>
            <td>Sous-total</td>
            <td>{{ subtotal|number_format(2, ',', ' ') }} €</td>
        </tr>
        <tr>
            <td>Frais de livraison</td>
            <td>{% if order.shippingCost > 0 %}{{ order.shippingCost|number_format(2, ',', ' ') }} €{% else %}Offert{% endif %}</td>
        </tr>
        {% if order.discountAmount and order.discountAmount > 0 %}
        <tr class="row-discount">
            <td>Remise{% if order.promoCode %} ({{ order.promoCode }}){% endif %}</td>
            <td>- {{ order.discountAmount|number_format(2, ',', ' ') }} €</td>
        </tr>
        {% endif %}
        <tr class="row-total">
            <td>TOTAL</td>
            <td>{{ order.totalAmount|number_format(2, ',', ' ') }} €</td>
        </tr>
    </table>
</div>

<div class="payment-info">
    {% if order.paidAt %}
        Paiement reçu le {{ order.paidAt|date('d/m/Y') }}{% if order.paymentMethod %} via {{ order.paymentMethod }}{% endif %}
    {% else %}
        En attente de paiement
    {% endif %}
    — Ce document est un récapitulatif de commande et ne constitue pas une facture fiscale.
</div>

<div class="payment-info" style="margin-top: 8px;">
    <strong>{{ tvaMention is defined and tvaMention ? tvaMention : 'TVA non applicable, article 293 B du CGI' }}</strong>
</div>

<div class="footer">
    Khamareo — Une vie saine au naturel<br>
    Document généré le {{ generatedAt|date('d/m/Y à H:i') }}
</div>

</body>
</html>
