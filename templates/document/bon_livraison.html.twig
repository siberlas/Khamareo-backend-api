<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 11px; color: #333; line-height: 1.5; }

        .header { display: flex; justify-content: space-between; align-items: flex-start; padding-bottom: 14px; margin-bottom: 20px; }
        .header-left { display: flex; align-items: center; gap: 10px; }
        .logo-img { height: 36px; width: auto; }
        .brand-name { font-size: 20px; font-weight: 600; color: #4A2E20; letter-spacing: 0.06em; text-transform: uppercase; }
        .brand-tagline { font-size: 9px; font-style: italic; color: #9A8A7A; margin-top: 2px; }
        .doc-meta { text-align: right; }
        .doc-title { font-size: 16px; font-weight: 700; color: #4A2E20; text-transform: uppercase; letter-spacing: 0.1em; }
        .doc-ref { font-size: 10px; color: #7A5C47; margin-top: 4px; }

        .gold-bar { height: 2px; background: linear-gradient(to right, #4A2E20, #D8A35D, #4A2E20); margin-bottom: 20px; }

        .addresses { display: flex; gap: 20px; margin-bottom: 20px; }
        .address-block { flex: 1; padding: 10px 12px; border: 1px solid #ddd; border-radius: 4px; }
        .address-block h3 { font-size: 9px; text-transform: uppercase; letter-spacing: 0.1em; color: #D8A35D; margin-bottom: 6px; padding-bottom: 4px; border-bottom: 1px solid #eee; }
        .address-block p { margin: 1px 0; font-size: 11px; }

        .tracking-box { padding: 8px 12px; margin-bottom: 18px; font-size: 11px; border-left: 3px solid #D8A35D; background: #faf8f5; }
        .tracking-label { color: #7A5C47; }
        .tracking-number { font-weight: 700; font-size: 13px; color: #4A2E20; letter-spacing: 1px; font-family: monospace; }

        .parcels-summary { margin-bottom: 18px; }
        .parcels-summary table { width: 100%; border-collapse: collapse; }
        .parcels-summary th { background: #faf8f5; color: #4A2E20; padding: 5px 8px; text-align: left; font-size: 9px; text-transform: uppercase; border-bottom: 1px solid #ddd; }
        .parcels-summary td { padding: 5px 8px; border-bottom: 1px solid #eee; font-size: 10px; }

        table { width: 100%; border-collapse: collapse; margin-bottom: 16px; }
        thead th { background: #4A2E20; color: white; padding: 7px 8px; text-align: left; font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
        thead th.text-center { text-align: center; }
        tbody tr:nth-child(even) { background: #faf8f5; }
        tbody td { padding: 7px 8px; border-bottom: 1px solid #eee; font-size: 11px; }
        tbody td.text-center { text-align: center; }
        .qty-shipped { font-weight: 700; font-size: 13px; color: #D8A35D; }

        .signature-zone { margin-top: 28px; display: flex; gap: 24px; }
        .signature-box { flex: 1; border: 1px dashed #ccc; border-radius: 4px; padding: 14px; min-height: 70px; text-align: center; color: #bbb; font-size: 10px; }

        .footer { margin-top: 30px; padding-top: 10px; border-top: 1px solid #eee; font-size: 9px; color: #aaa; text-align: center; }
    </style>
</head>
<body>

{% set customerName = order.owner
    ? (order.owner.firstName ~ ' ' ~ order.owner.lastName)
    : (order.guestFirstName ~ ' ' ~ order.guestLastName) %}

<div class="header">
    <div>
        <div class="header-left">
            <img src="https://res.cloudinary.com/dtdumh0gv/image/upload/v1774628630/logo-khamareo_t0wufe.png" alt="Khamareo" class="logo-img">
            <div>
                <div class="brand-name">Khamareo</div>
                <div class="brand-tagline">Une vie saine au naturel</div>
            </div>
        </div>
        <div style="font-size: 9px; color: #999; margin-top: 6px;">
            akwaaba@khamareo.com — www.khamareo.com
        </div>
    </div>
    <div class="doc-meta">
        <div class="doc-title">Bon de Livraison</div>
        <div class="doc-ref">
            Commande N° {{ order.orderNumber }}<br>
            {% if parcel %}
                Colis {{ parcel.parcelNumber ?? '1' }}/{{ order.parcels|length }}<br>
            {% endif %}
            Émis le {{ generatedAt|date('d/m/Y') }}
        </div>
    </div>
</div>

<div class="gold-bar"></div>

<div class="addresses">
    <div class="address-block">
        <h3>Expéditeur</h3>
        <p><strong>Khamareo</strong></p>
        <p>akwaaba@khamareo.com</p>
        <p>www.khamareo.com</p>
    </div>
    <div class="address-block">
        <h3>Destinataire</h3>
        <p><strong>{{ customerName }}</strong></p>
        <p>{{ order.shippingAddress.streetAddress }}</p>
        <p>{{ order.shippingAddress.postalCode }} {{ order.shippingAddress.city }}</p>
        <p>{{ order.shippingAddress.country }}</p>
    </div>
    <div class="address-block">
        <h3>Transport</h3>
        {% if order.carrier %}
            <p><strong>Transporteur :</strong> {{ order.carrier.name }}</p>
        {% endif %}
        {% if parcel %}
            {% if parcel.weightKg is not null %}<p><strong>Poids :</strong> {{ parcel.weightKg }} kg</p>{% endif %}
        {% else %}
            <p><strong>Nombre de colis :</strong> {{ parcels|length }}</p>
        {% endif %}
    </div>
</div>

{% if parcel and parcel.trackingNumber %}
<div class="tracking-box">
    <span class="tracking-label">N° de suivi : </span>
    <span class="tracking-number">{{ parcel.trackingNumber }}</span>
</div>
{% elseif parcels|length > 1 %}
<div class="parcels-summary">
    <table>
        <thead>
            <tr>
                <th>Colis</th>
                <th>N° de suivi</th>
                <th>Poids</th>
            </tr>
        </thead>
        <tbody>
            {% for p in parcels %}
            <tr>
                <td>Colis {{ loop.index }}</td>
                <td><strong>{{ p.trackingNumber ?? '—' }}</strong></td>
                <td>{{ p.weightKg is not null ? p.weightKg ~ ' kg' : '—' }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}

<table>
    <thead>
        <tr>
            <th>Désignation</th>
            <th class="text-center">Qté commandée</th>
            <th class="text-center">Qté expédiée</th>
        </tr>
    </thead>
    <tbody>
        {% if parcel %}
            {% for parcelItem in parcel.items %}
            <tr>
                <td><strong>{{ parcelItem.orderItem.product.name }}</strong></td>
                <td class="text-center">{{ parcelItem.orderItem.quantity }}</td>
                <td class="text-center"><span class="qty-shipped">{{ parcelItem.quantity }}</span></td>
            </tr>
            {% endfor %}
        {% else %}
            {% for item in order.items %}
            <tr>
                <td><strong>{{ item.product.name }}</strong></td>
                <td class="text-center">{{ item.quantity }}</td>
                <td class="text-center"><span class="qty-shipped">{{ item.quantity }}</span></td>
            </tr>
            {% endfor %}
        {% endif %}
    </tbody>
</table>

<div class="signature-zone">
    <div class="signature-box">
        <strong>Expédié par</strong>
        <p>Date : {{ generatedAt|date('d/m/Y') }}</p>
        <p>Khamareo</p>
    </div>
    <div class="signature-box">
        <strong>Reçu par le destinataire</strong>
        <p>Date : ___/___/______</p>
        <p>Signature</p>
    </div>
</div>

<div class="footer">
    Khamareo — Une vie saine au naturel<br>
    Document généré le {{ generatedAt|date('d/m/Y à H:i') }}
</div>

</body>
</html>
